<?xml version="1.0" ?>
<mujoco model="alicia_arm">
  <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>
  
  <default>
    <joint armature="0.1" damping="0.1" limited="true"/>
    <geom conaffinity="0" condim="3" density="5.0" friction="1 0.5 0.001" rgba="0.8 0.6 0.4 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4" width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" dirfromto="0 0 0 0 0 -1" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom name="floor" pos="0 0 0" size="1 1 0.1" type="plane" material="grid"/>
    
    <!-- 机械臂基座 -->
    <body name="base" pos="0 0 0.1">
      <geom name="base_link" pos="0 0 0" size="0.05 0.05 0.05" type="box" rgba="0.2 0.2 0.2 1"/>
      
      <!-- 关节1 - 基座旋转 -->
      <body name="joint1" pos="0 0 0.05">
        <joint name="joint1" axis="0 0 1" pos="0 0 0" range="-3.14 3.14" type="hinge"/>
        <geom name="link1" pos="0 0 0.05" size="0.03 0.03 0.05" type="box" rgba="0.8 0.2 0.2 1"/>
        
        <!-- 关节2 - 大臂俯仰 -->
        <body name="joint2" pos="0 0 0.1">
          <joint name="joint2" axis="0 1 0" pos="0 0 0" range="-1.57 1.57" type="hinge"/>
          <geom name="link2" pos="0.05 0 0" size="0.15 0.03 0.03" type="box" rgba="0.2 0.8 0.2 1"/>
          
          <!-- 关节3 - 小臂俯仰 -->
          <body name="joint3" pos="0.15 0 0">
            <joint name="joint3" axis="0 1 0" pos="0 0 0" range="-3.14 3.14" type="hinge"/>
            <geom name="link3" pos="0.05 0 0" size="0.1 0.03 0.03" type="box" rgba="0.2 0.2 0.8 1"/>
            
            <!-- 关节4 - 腕部旋转 -->
            <body name="joint4" pos="0.1 0 0">
              <joint name="joint4" axis="1 0 0" pos="0 0 0" range="-3.14 3.14" type="hinge"/>
              <geom name="link4" pos="0 0 0.03" size="0.03 0.03 0.06" type="box" rgba="0.8 0.8 0.2 1"/>
              
              <!-- 关节5 - 腕部俯仰 -->
              <body name="joint5" pos="0 0 0.06">
                <joint name="joint5" axis="0 1 0" pos="0 0 0" range="-1.57 1.57" type="hinge"/>
                <geom name="link5" pos="0 0 0.02" size="0.02 0.02 0.04" type="box" rgba="0.8 0.2 0.8 1"/>
                
                <!-- 关节6 - 末端旋转 -->
                <body name="joint6" pos="0 0 0.04">
                  <joint name="joint6" axis="0 0 1" pos="0 0 0" range="-3.14 3.14" type="hinge"/>
                  <geom name="link6" pos="0 0 0.02" size="0.015 0.015 0.04" type="box" rgba="0.2 0.8 0.8 1"/>
                  
                  <!-- 末端执行器 -->
                  <body name="end_effector" pos="0 0 0.06">
                    <geom name="gripper_base" pos="0 0 0" size="0.02 0.02 0.02" type="box" rgba="0.5 0.5 0.5 1"/>
                    
                    <!-- 夹爪 -->
                    <body name="gripper_joint" pos="0 0 0.02">
                      <joint name="gripper" axis="0 1 0" pos="0 0 0" range="0 1.57" type="hinge"/>
                      <geom name="gripper_left" pos="-0.01 0 0" size="0.005 0.01 0.02" type="box" rgba="0.3 0.3 0.3 1"/>
                      <geom name="gripper_right" pos="0.01 0 0" size="0.005 0.01 0.02" type="box" rgba="0.3 0.3 0.3 1"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor joint="joint1" gear="100"/>
    <motor joint="joint2" gear="100"/>
    <motor joint="joint3" gear="100"/>
    <motor joint="joint4" gear="100"/>
    <motor joint="joint5" gear="100"/>
    <motor joint="joint6" gear="100"/>
    <motor joint="gripper" gear="50"/>
  </actuator>

  <sensor>
    <jointpos name="joint_pos" joint="joint1"/>
    <jointpos name="joint_pos" joint="joint2"/>
    <jointpos name="joint_pos" joint="joint3"/>
    <jointpos name="joint_pos" joint="joint4"/>
    <jointpos name="joint_pos" joint="joint5"/>
    <jointpos name="joint_pos" joint="joint6"/>
    <jointpos name="gripper_pos" joint="gripper"/>
  </sensor>
</mujoco>